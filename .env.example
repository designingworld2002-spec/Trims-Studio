# Trims Studio environment configuration.
#
# Copy this file to `.env` and fill in your real keys. Vite exposes any var
# starting with VITE_ to the browser bundle — never put server-only secrets
# (service-role keys, webhook secrets, etc.) in this file.

# ---- Supabase ----
# Project URL from Supabase → Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Anon (public) key from the same screen. Safe to ship to the browser.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Storage bucket where PNG previews are uploaded.
# Create this bucket in Supabase → Storage and enable public read access.
VITE_SUPABASE_DESIGNS_BUCKET=design-previews

# ---- Shopify ----
# Where to send the customer after Continue. The studio appends:
#   ?design_id=<uuid>
#   &preview_url=<public PNG url>   (when stored remotely)
#   &product=<slug>
#   &length=<mm>&width=<mm>
#   &customer_id=<id>               (when logged in)
VITE_SHOPIFY_FINALIZE_URL=https://trims.in/pages/finalize
